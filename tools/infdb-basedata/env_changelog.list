# Database connection properties
LIQUIBASE_COMMAND_URL=jdbc:postgresql://${SERVICES_POSTGRES_HOST}:${SERVICES_POSTGRES_EXPOSED_PORT}/${SERVICES_POSTGRES_DB}
LIQUIBASE_COMMAND_USERNAME=${SERVICES_POSTGRES_USER}
LIQUIBASE_COMMAND_PASSWORD=${SERVICES_POSTGRES_PASSWORD}
LIQUIBASE_DRIVER=org.postgresql.Driver

# changelog database schema in public schema
LIQUIBASE_LIQUIBASE_SCHEMA_NAME=public

LIQUIBASE_LOG_LEVEL=info

# the following path is relative from /liquibase/changelog by default
LIQUIBASE_COMMAND_CHANGELOG_FILE=./changelog-master.yml

# the following properties are used to substitute liquibase changelogs.
EPSG=25832
output_schema=basedata